# Notion
NOTION_TOKEN=secret_xxx
NOTION_PRD_PAGE_ID=
NOTION_IMPL_LOG_PAGE_ID=

# Notion DB IDs（collection IDs — config.py が自動解決して書き込む）
NOTION_DB_SBI_CSV_IMPORT=
NOTION_DB_ASSETS_MASTER=
NOTION_DB_HOLDINGS=
NOTION_DB_INVESTMENT_POLICY=
NOTION_DB_AGENT=
NOTION_DB_AGENT_ANALYSIS=
NOTION_DB_WEEKLY_REPORTS=
NOTION_DB_PORTFOLIO_SNAPSHOTS=

# LLM設定（Provider / Modelは切り替え可能。初期候補: gemini）
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
LLM_MODEL_PERSONA=gemini-3.5-flash
LLM_MODEL_SYNTHESIZER=gemini-3.1-pro-preview

# Claude API（LLM_PROVIDER=claude の場合に使用）
ANTHROPIC_API_KEY=sk-ant-xxx

# 実行設定
TIMEZONE=Asia/Tokyo
